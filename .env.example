# =============================================================================
# TaskPay — Environment Variables
# Copy to `.env.local` and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# App URL (required)
# Used for SIWE, OAuth callbacks, notifications, and absolute links.
# Local: http://localhost:3000
# Production: https://www.trytaskpay.com
# Cloudflare tunnel: https://your-subdomain.trycloudflare.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_URL=http://localhost:3000

# Canonical web dapp URL — used for X OAuth when NEXT_PUBLIC_URL is a mini app / tunnel URL
# Production: https://www.trytaskpay.com
APP_WEB_URL=https://www.trytaskpay.com

# SIWE wallet sign-in uses APP_WEB_URL (not NEXT_PUBLIC_URL / Vercel mini app URL)
# Optional override:
# SIWE_DOMAIN=www.trytaskpay.com

# Optional — Farcaster Quick Auth domain allowlist
# QUICK_AUTH_DOMAIN=trytaskpay.com

# -----------------------------------------------------------------------------
# Session & auth (required in production)
# -----------------------------------------------------------------------------
# Random string — generate: openssl rand -base64 32
SESSION_SECRET=

# Optional client-side API guard (defaults to placeholder if unset)
NEXT_PUBLIC_API_SECRET_KEY=

# -----------------------------------------------------------------------------
# MongoDB (required)
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/taskpay

# -----------------------------------------------------------------------------
# Upstash Redis (required for Farcaster mini app notifications / KV)
# https://console.upstash.com/
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Smart contracts — Arbitrum One (public, safe in client)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CUSTOM_TASK_ESCROW_ADDRESS=0x1646172573E7D2fef7C32DE6ee96A38486428202

# TaskPay.sol address is in lib/contracts.ts (TASK_ESCROW_ADDRESS).
# CustomTaskPay.sol uses NEXT_PUBLIC_CUSTOM_TASK_ESCROW_ADDRESS above.

# Backend wallet that signs EIP-712 claim/reclaim messages (required — keep secret)
# Must match the `signer` address set on TaskPay.sol + CustomTaskPay.sol
ESCROW_SIGNER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Neynar — Farcaster API (required)
# https://dev.neynar.com/
# Used for: user lookup, follow/cast verification, mini app webhooks, spam labels
# -----------------------------------------------------------------------------
NEYNAR_API_KEY=

# Optional extra keys for rate-limit rotation
# NEYNAR_API_KEY2=
# NEYNAR_API_KEY3=
# NEYNAR_API_KEY4=
# NEYNAR_API_KEY5=

# Optional — Farcaster hub / signed key (auto-boost, signer registration)
# FARCASTER_DEVELOPER_MNEMONIC=
# APP_FID=
# SIGNED_KEY_REQUEST_DEADLINE_SECS=86400
# NEYNAR_SUBMIT_MESSAGE_URL=https://snapchain-api.neynar.com/v1/submitMessage
# FARCASTER_HUB_GRPC=
# FARCASTER_HUB_GRPC_DISABLED=1

# Optional — push notifications when new quests launch (Warpcast internal API)
# FARCASTER_AUTHORIZATION=
# FARCASTER_COOKIE=

# -----------------------------------------------------------------------------
# X (Twitter) — OAuth connect (required for "Connect X" in profile)
#
# 1. Go to https://developer.x.com/en/portal/dashboard
# 2. Create a Project + App (or use existing)
# 3. User authentication settings ? OAuth 2.0 ? Enable
# 4. Type of App: Web App
# 5. Callback URL (add both for dev + prod):
#      http://localhost:3000/api/auth/x/callback
#      https://www.trytaskpay.com/api/auth/x/callback
# 6. Website URL: https://www.trytaskpay.com
# 7. Permissions: Read (tweet.read, users.read)
# 8. Copy OAuth 2.0 Client ID + Client Secret below
#
# Flow: user connects wallet ? clicks Connect X ? /api/auth/x/start ?
#       X login ? /api/auth/x/callback ? X username linked to wallet
# -----------------------------------------------------------------------------
X_CLIENT_ID=
X_CLIENT_SECRET=

# Callback = APP_WEB_URL + /api/auth/x/callback (or set full URL below)
# X portal Callback URI: https://www.trytaskpay.com/api/auth/x/callback
# X_OAUTH_CALLBACK_URL=https://www.trytaskpay.com/api/auth/x/callback

# -----------------------------------------------------------------------------
# X (Twitter) — Quest verification via RapidAPI (required for X quests)
#
# TaskPay does NOT use the official X API for follow/like/retweet checks.
# It uses RapidAPI "Twitter API45" (twitter-api45.p.rapidapi.com).
#
# 1. Go to https://rapidapi.com/twitter-api45/api/twitter-api45
# 2. Subscribe to a plan
# 3. Copy your RapidAPI key
# 4. Used for: X follow verify, tweet lookup, search users, timeline checks
#
# Optional RAPIDAPI_KEY2–5 for automatic key rotation on rate limits
# -----------------------------------------------------------------------------
RAPIDAPI_KEY=

# RAPIDAPI_KEY2=
# RAPIDAPI_KEY3=
# RAPIDAPI_KEY4=
# RAPIDAPI_KEY5=

# -----------------------------------------------------------------------------
# Alchemy — Arbitrum RPC (required for custom on-chain quest verification)
# https://dashboard.alchemy.com/
# Used to fetch tx receipts + scan wallet transactions
# -----------------------------------------------------------------------------
ALCHEMY_API_KEY=

# Optional — full RPC URL override (otherwise built from ALCHEMY_API_KEY)
# ALCHEMY_ARBITRUM_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# -----------------------------------------------------------------------------
# Pinata — IPFS uploads (optional — quest images / metadata / avatars)
# https://app.pinata.cloud/
# -----------------------------------------------------------------------------
PINATA_API_KEY=
PINATA_SECRET_API_KEY=
# PINATA_GATEWAY=ipfs.filebase.io

# Optional extra Pinata key pairs for rotation
# PINATA_API_KEY_2=
# PINATA_SECRET_API_KEY_2=

# -----------------------------------------------------------------------------
# Auto-boost (optional — server-side boost_lite execution)
# -----------------------------------------------------------------------------
# BOOST_LITE_BATCH_SIZE=5
# BOOST_LITE_INTER_BATCH_MS=1000

# -----------------------------------------------------------------------------
# Farcaster signed keys — encryption (optional)
# Generate: pnpm generate:signer-secret
# -----------------------------------------------------------------------------
# SIGNER_ENCRYPTION_SECRET=

# =============================================================================
# Quick checklist
# =============================================================================
# Minimum to run locally:
#   NEXT_PUBLIC_URL, MONGODB_URI, NEYNAR_API_KEY, SESSION_SECRET
#
# Wallet + claims:
#   ESCROW_SIGNER_PRIVATE_KEY, NEXT_PUBLIC_CUSTOM_TASK_ESCROW_ADDRESS
#
# Connect X account (OAuth):
#   X_CLIENT_ID, X_CLIENT_SECRET
#
# X quest verify (follow / boost / bundle):
#   RAPIDAPI_KEY
#
# Custom on-chain quests:
#   ALCHEMY_API_KEY
#
# Mini app notifications:
#   UPSTASH_REDIS_REST_URL, UPSTASH_REDIS_REST_TOKEN
# =============================================================================

# Celo / GoodDollar
NEXT_PUBLIC_CELO_SOCIAL_ESCROW_ADDRESS=
NEXT_PUBLIC_CELO_CUSTOM_ESCROW_ADDRESS=
# UBI Pool fee amount in G$ (e.g. 2200 = 2,200 G$, roughly UBI Pool fee amount in G$ (e.g. 500 = 500 G$, roughly $0.05).25)
NEXT_PUBLIC_UBI_FEE_G_DOLLAR=2200
